<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissões necessárias -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:label="Letrinhas"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Especifica que esta é a Activity principal -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />

            <!-- Intent filter para tornar a Activity o ponto de entrada -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!--
            Segunda camada de proteção contra inicialização automática do Firebase.

            Contexto: firebase-common.aar (dependência transitiva de firebase_core,
            firebase_auth, cloud_firestore) declara FirebaseInitProvider no seu próprio
            AndroidManifest.xml. Esse ContentProvider roda no startup do processo Android,
            ANTES de qualquer código Dart, e chama FirebaseApp.initializeApp(context).
            Se o provider conseguir inicializar, quando main.dart chegar em
            Firebase.initializeApp() o app [DEFAULT] já existe → "duplicate-app".

            Primeira camada de proteção (causa raiz): remoção do plugin
            com.google.gms.google-services do build (ver android/app/build.gradle).
            Sem o plugin, nenhum google-services.xml é gerado. Sem esse XML,
            FirebaseInitProvider não consegue ler a configuração e retorna null —
            sem auto-inicialização nativa.

            Esta entrada (tools:node="remove") é a segunda camada: remove
            FirebaseInitProvider do AndroidManifest mesclado final, garantindo que o
            provider nem seja registrado no processo, independente de qualquer outro
            mecanismo que tente re-adicioná-lo.

            Juntas, as duas camadas garantem que o ÚNICO ponto de inicialização
            do Firebase é a chamada Dart em main.dart, protegida pelo guard
            Firebase.apps.isEmpty.
        -->
        <provider
            android:name="com.google.firebase.provider.FirebaseInitProvider"
            android:authorities="${applicationId}.firebaseinitprovider"
            android:exported="false"
            android:initOrder="100"
            tools:node="remove" />
    </application>
</manifest>
